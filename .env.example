# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Model Configuration
PRIMARY_LLM_PROVIDER=anthropic
PRIMARY_MODEL=claude-sonnet-4-6
VERIFIER_LLM_PROVIDER=openai
VERIFIER_MODEL=gpt-4o
HEAVY_MODEL=claude-opus-4-6

# Database
DATABASE_URL=sqlite:///./memory/aifactory.db
DATABASE_URL_DEV=sqlite:///./memory/aifactory.db
DATABASE_URL_PROD=postgresql://postgres:yourpassword@localhost:5432/dorjea

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Token Control
MAX_TOKENS_PER_TASK=10000
DAILY_TOKEN_BUDGET=50000

# 境内支付（微信 Native / 支付宝当面付）
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
WECHAT_MCHID=
WECHAT_APPID=
WECHAT_CERT_SERIAL=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY_PEM=
WECHAT_PRIVATE_KEY_PATH=
WECHAT_NOTIFY_URL=
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY_PEM=
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_ALIPAY_PUBLIC_KEY_PEM=
ALIPAY_ALIPAY_PUBLIC_KEY_PATH=
ALIPAY_NOTIFY_URL=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# Ports
API_PORT=8000
FILESYSTEM_MCP_PORT=8001
REGISTRY_MCP_PORT=8002
GITHUB_MCP_PORT=8003

# Observability
ENABLE_TOKEN_MONITOR=true
ENABLE_AGENT_LOGGING=true

# Auth & admin (超级管理员 / 站点管理员)
# JWT 签名密钥（生产环境务必设置固定值）
JWT_SECRET_KEY=
# 系统所有者邮箱：登录后 is_owner，管理后台全权限，套餐视为 owner
OWNER_EMAIL=
# 站点管理员邮箱：登录后 is_admin、enterprise 套餐（非 OWNER，不能访问需 OWNER 的管理接口）
ADMIN_EMAIL=
# 管理后台备用密钥（与 Bearer 令牌二选一）；请使用长随机串
ADMIN_SECRET_KEY=
# 展示用（/admin/stats 等）
SYSTEM_NAME=元芯智能
SYSTEM_DOMAIN=agentcore.ai
